{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.schemas/edge_a/auth.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "op",
    "token"
  ],
  "properties": {
    "op": {
      "const": "auth"
    },
    "token": {
      "type": "string",
      "minLength": 1
    }
  }
}
