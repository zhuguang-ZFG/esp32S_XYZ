{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.schemas/edge_a/job_status_event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "event"
  ],
  "properties": {
    "type": {
      "const": "event"
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "device_id",
        "task_id",
        "ts",
        "seq",
        "payload"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "const": "job_status"
        },
        "device_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "ts": {
          "type": "integer",
          "minimum": 0
        },
        "seq": {
          "type": "integer",
          "minimum": 0
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "phase",
            "capability"
          ],
          "properties": {
            "phase": {
              "type": "string",
              "enum": [
                "accepted",
                "running",
                "progress",
                "done",
                "failed",
                "cancelled",
                "rejected"
              ]
            },
            "capability": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "enum": [
                "client",
                "voice"
              ]
            },
            "progress": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "done_segments": {
                  "type": "integer",
                  "minimum": 0
                },
                "total_segments": {
                  "type": "integer",
                  "minimum": 1
                },
                "percent": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                }
              }
            },
            "tts_hint": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "tts_event"
              ],
              "properties": {
                "tts_event": {
                  "type": "string",
                  "enum": [
                    "task_started",
                    "task_done",
                    "task_failed",
                    "task_rejected",
                    "device_info_reply"
                  ]
                },
                "text": {
                  "type": "string"
                },
                "task_id": {
                  "type": "string"
                },
                "device_id": {
                  "type": "string"
                },
                "capability": {
                  "type": "string"
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "client",
                    "voice"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
