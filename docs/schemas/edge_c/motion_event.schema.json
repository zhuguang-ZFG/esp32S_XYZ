{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.schemas/edge_c/motion_event.schema.json",
  "title": "Edge-C motion_event 上行（U8→DeviceServer WSS）",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "type", "task_id", "phase"],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "type": { "const": "motion_event" },
    "task_id": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["accepted", "running", "progress", "done", "failed", "cancelled", "rejected"]
    },
    "device_id": { "type": "string" },
    "capability": { "type": "string" },
    "source": { "type": "string", "enum": ["client", "voice"] },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "done_segments": { "type": "integer", "minimum": 0 },
        "total_segments": { "type": "integer", "minimum": 1 },
        "percent": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "tts_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tts_event"],
      "properties": {
        "tts_event": {
          "type": "string",
          "enum": ["task_started", "task_done", "task_failed", "task_rejected", "device_info_reply"]
        },
        "text": { "type": "string" },
        "task_id": { "type": "string" },
        "device_id": { "type": "string" },
        "capability": { "type": "string" },
        "source": { "type": "string", "enum": ["client", "voice"] }
      }
    }
  }
}
